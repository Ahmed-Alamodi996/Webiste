# MongoDB connection string
MONGODB_URI=mongodb://127.0.0.1/inst-website

# Secret used by Payload CMS for authentication (generate a random string)
PAYLOAD_SECRET=your-secret-here

# Public site URL (used for SEO, OG images, sitemaps)
NEXT_PUBLIC_SITE_URL=https://inst.tech

# Admin password used by the seed script
ADMIN_PASSWORD=change-me
