# ============================================================
# Revenue Assurance Platform - Environment Configuration
# Copy this file to .env.dev / .env.uat / .env.prod
# ============================================================

# --- Environment ---
ENVIRONMENT=dev
DEBUG=true
LOG_LEVEL=DEBUG
APP_NAME=ra-platform
APP_VERSION=1.0.0

# --- API Server ---
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4
API_RELOAD=true

# --- PostgreSQL (Metadata Store) ---
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=ra_metadata
POSTGRES_USER=ra_admin
POSTGRES_PASSWORD=CHANGE_ME_IN_PRODUCTION
POSTGRES_POOL_SIZE=20
POSTGRES_MAX_OVERFLOW=10
POSTGRES_ECHO=false

# --- Oracle (Data Warehouse) ---
ORACLE_HOST=localhost
ORACLE_PORT=1521
ORACLE_SID=ORCL
ORACLE_USER=recon_prd
ORACLE_PASSWORD=CHANGE_ME_IN_PRODUCTION
ORACLE_POOL_MIN=2
ORACLE_POOL_MAX=10
ORACLE_POOL_INCREMENT=1
ORACLE_HOME=/opt/oracle/instantclient

# --- Redis (Job Queue / Cache) ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
REDIS_MAX_CONNECTIONS=50

# --- JWT Authentication ---
JWT_SECRET_KEY=CHANGE_ME_USE_OPENSSL_RAND_HEX_64
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# --- Job Configuration ---
JOB_DEFAULT_TIMEOUT_SECONDS=3600
JOB_MAX_RETRIES=3
JOB_RETRY_BACKOFF_BASE=2
JOB_CHUNK_SIZE=50000
JOB_PARALLEL_WORKERS=4

# --- SLA Configuration ---
SLA_EXPORT_MAX_DURATION_MINUTES=30
SLA_LOAD_MAX_DURATION_MINUTES=60
SLA_REFRESH_MAX_DURATION_MINUTES=120
SLA_BREACH_ALERT_ENABLED=true

# --- Paths ---
EXPORT_TEMP_DIR=/tmp/ra-exports
BACKUP_DIR=/tmp/ra-backups
CTL_DIR=/tmp/ra-ctl
SQLLDR_BIN_PATH=/opt/oracle/instantclient/sqlldr
