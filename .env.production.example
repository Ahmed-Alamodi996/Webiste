# ============================================
# Production Environment Variables
# ============================================
# Copy this file to .env.production and fill in real values
# NEVER commit .env.production to git
# ============================================

# --- Site ---
SITE_URL=https://yourdomain.com

# --- MongoDB (used by Docker Compose) ---
MONGO_USER=inst_admin
MONGO_PASSWORD=CHANGE_ME_TO_A_STRONG_PASSWORD

# --- Payload CMS ---
# Generate with: openssl rand -hex 32
PAYLOAD_SECRET=CHANGE_ME_GENERATE_WITH_openssl_rand_hex_32

# --- Admin (for seed script only) ---
ADMIN_PASSWORD=CHANGE_ME_STRONG_ADMIN_PASSWORD
