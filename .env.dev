ENVIRONMENT=dev
DEBUG=true
LOG_LEVEL=DEBUG
APP_NAME=ra-platform
APP_VERSION=1.0.0-dev

API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=2
API_RELOAD=true

POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=ra_metadata_dev
POSTGRES_USER=ra_admin
POSTGRES_PASSWORD=dev_password_change_me
POSTGRES_POOL_SIZE=10
POSTGRES_MAX_OVERFLOW=5
POSTGRES_ECHO=true

ORACLE_HOST=oracle-dev
ORACLE_PORT=1521
ORACLE_SID=DEVDB
ORACLE_USER=recon_dev
ORACLE_PASSWORD=dev_oracle_change_me
ORACLE_POOL_MIN=1
ORACLE_POOL_MAX=5
ORACLE_POOL_INCREMENT=1
ORACLE_HOME=/opt/oracle/instantclient

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
REDIS_MAX_CONNECTIONS=20

JWT_SECRET_KEY=dev-secret-key-not-for-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=480
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

JOB_DEFAULT_TIMEOUT_SECONDS=3600
JOB_MAX_RETRIES=3
JOB_RETRY_BACKOFF_BASE=2
JOB_CHUNK_SIZE=10000
JOB_PARALLEL_WORKERS=2

SLA_EXPORT_MAX_DURATION_MINUTES=60
SLA_LOAD_MAX_DURATION_MINUTES=120
SLA_REFRESH_MAX_DURATION_MINUTES=240
SLA_BREACH_ALERT_ENABLED=false

EXPORT_TEMP_DIR=/tmp/ra-exports
BACKUP_DIR=/tmp/ra-backups
CTL_DIR=/tmp/ra-ctl
SQLLDR_BIN_PATH=/opt/oracle/instantclient/sqlldr
